@model List<SonheiComBicho.Models.Aposta>

@{
    var jogador = ViewBag.Jogador as SonheiComBicho.Models.Jogador;
    var bichos = SonheiComBicho.Models.Bicho.GetBichos();
}

<style>
    body {
        background: #1a3a1a;
    }

    .jb-wrap {
        background: #1a3a1a;
        font-family: 'Oswald', sans-serif;
        border: 2px solid #8a6a00;
        border-radius: 8px;
        overflow: hidden;
        max-width: 900px;
        margin: 20px auto;
    }

    .jb-header {
        background: #0d2a0d;
        border-bottom: 2px solid #8a6a00;
        padding: 8px 16px;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .jb-logo {
        background: #000;
        border: 2px solid #c8a000;
        border-radius: 8px;
        padding: 4px 12px;
        color: #5ecb5e;
        font-size: 14px;
        font-weight: 700;
        letter-spacing: 1px;
    }

    .jb-player {
        text-align: right;
        color: #e8d080;
        font-size: 13px;
    }

        .jb-player span {
            color: #fff;
            font-weight: 600;
        }

    .jb-body {
        padding: 16px;
    }

    .jb-titulo {
        text-align: center;
        margin-bottom: 16px;
    }

    .jb-titulo-box {
        display: inline-block;
        border: 2px solid #c8a000;
        border-radius: 8px;
        padding: 8px 32px;
        color: #f0d060;
        font-size: 20px;
        font-weight: 700;
        letter-spacing: 2px;
        background: #0d2a0d;
    }

    .jb-row {
        display: grid;
        grid-template-columns: 1fr 2fr 2fr;
        gap: 8px;
        margin-bottom: 8px;
        align-items: center;
    }

    .jb-cell {
        background: #0d2a0d;
        border: 2px solid #5a7a30;
        border-radius: 20px;
        padding: 8px 16px;
        color: #f0d060;
        font-size: 13px;
        font-weight: 600;
        text-align: center;
    }

        .jb-cell.ganhou {
            border-color: #5ecb5e;
            color: #5ecb5e;
        }

        .jb-cell.perdeu {
            border-color: #ff4444;
            color: #ff4444;
        }

        .jb-cell.depositou {
            border-color: #60a0ff;
            color: #60a0ff;
        }

    .jb-btn {
        display: inline-block;
        background: #3a6a10;
        border: 2px solid #c8a000;
        border-radius: 6px;
        color: #f0d060;
        font-family: 'Oswald', sans-serif;
        font-size: 15px;
        font-weight: 700;
        padding: 8px 24px;
        letter-spacing: 1px;
        cursor: pointer;
        text-decoration: none;
        margin: 8px 0;
    }

        .jb-btn:hover {
            background: #4a8a18;
            color: #f0d060;
        }

    .jb-footer {
        background: #0d2a0d;
        border-top: 2px solid #8a6a00;
        padding: 6px 16px;
        color: #8aaa60;
        font-size: 11px;
        display: flex;
        justify-content: space-between;
    }

    .jb-vazio {
        text-align: center;
        color: #8aaa60;
        padding: 32px;
        font-size: 16px;
    }
</style>

<link href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;600;700&display=swap" rel="stylesheet" />

<div class="jb-wrap">
    <div class="jb-header">
        <div style="color:#8aaa60;font-size:20px;">☰</div>
        <div class="jb-logo">SONHEI COM BICHO</div>
        <div class="jb-player">
            Jogador: <span>@jogador?.Nome</span><br />
            Saldo: <span>R$ @jogador?.Saldo.ToString("F2")</span>
        </div>
    </div>

    <div class="jb-body">
        <div class="jb-titulo">
            <div class="jb-titulo-box">HISTÓRICO DE TRANSAÇÕES</div>
        </div>

        <a href="/Aposta/Apostar?jogadorId=@jogador?.Id" class="jb-btn">+ NOVA APOSTA</a>

        @if (!Model.Any())
        {
            <div class="jb-vazio">Nenhuma aposta realizada ainda.</div>
        }
        else
        {
            @foreach (var a in Model)
            {
                var bicho = bichos.FirstOrDefault(b => b.Id == a.BichoId);
                <div class="jb-row">
                    <div class="jb-cell">@a.DataAposta.ToString("dd/MM/yyyy HH:mm")</div>
                    <div class="jb-cell @(a.Ganhou == true ? "ganhou" : "perdeu")">
                        @(a.Ganhou == true ? "Ganhou" : "Perdeu") — @bicho?.Nome (@a.Tipo)
                    </div>
                    <div class="jb-cell @(a.Ganhou == true ? "ganhou" : "perdeu")">
                        @(a.Ganhou == true ? "+ R$ " + a.ValorGanho.ToString("F2") : "- R$ " + a.ValorApostado.ToString("F2"))
                        &nbsp;|&nbsp; id: @a.Id.ToString("D7")
                    </div>
                </div>
            }
        }
    </div>

    <div class="jb-footer">
        <span>Histórico de apostas</span>
        <span>Saldo: R$ @jogador?.Saldo.ToString("F2")</span>
    </div>
</div>