@model SonheiComBicho.Models.Jogador

<style>
    body {
        background: #1a3a1a;
    }

    .jb-wrap {
        background: #1a3a1a;
        font-family: 'Oswald', sans-serif;
        border: 2px solid #8a6a00;
        border-radius: 8px;
        overflow: hidden;
        max-width: 500px;
        margin: 20px auto;
    }

    .jb-header {
        background: #0d2a0d;
        border-bottom: 2px solid #8a6a00;
        padding: 8px 16px;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .jb-logo {
        background: #000;
        border: 2px solid #c8a000;
        border-radius: 8px;
        padding: 4px 12px;
        color: #5ecb5e;
        font-size: 14px;
        font-weight: 700;
        letter-spacing: 1px;
    }

    .jb-body {
        padding: 24px;
    }

    .jb-box {
        background: #0d2a0d;
        border: 2px solid #c8a000;
        border-radius: 12px;
        padding: 24px;
    }

    .jb-titulo {
        color: #f0d060;
        font-size: 20px;
        font-weight: 700;
        text-align: center;
        letter-spacing: 2px;
        margin-bottom: 20px;
    }

    .jb-label {
        color: #8aaa60;
        font-size: 13px;
        font-weight: 600;
        margin-bottom: 4px;
        letter-spacing: 1px;
    }

    .jb-input {
        width: 100%;
        background: #1a3a1a;
        border: 2px solid #5a7a30;
        border-radius: 20px;
        color: #f0d060;
        font-family: 'Oswald', sans-serif;
        font-size: 15px;
        padding: 10px 16px;
        box-sizing: border-box;
        margin-bottom: 16px;
    }

        .jb-input:focus {
            border-color: #c8a000;
            outline: none;
        }

        .jb-input::placeholder {
            color: #3a5a20;
        }

    .jb-btn {
        display: block;
        width: 100%;
        background: #3a6a10;
        border: 2px solid #c8a000;
        border-radius: 20px;
        color: #f0d060;
        font-family: 'Oswald', sans-serif;
        font-size: 18px;
        font-weight: 700;
        padding: 12px;
        letter-spacing: 2px;
        cursor: pointer;
        text-align: center;
        margin-top: 8px;
    }

        .jb-btn:hover {
            background: #4a8a18;
        }

    .jb-voltar {
        display: block;
        text-align: center;
        color: #8aaa60;
        font-size: 13px;
        margin-top: 12px;
        text-decoration: none;
    }

        .jb-voltar:hover {
            color: #f0d060;
        }

    .jb-footer {
        background: #0d2a0d;
        border-top: 2px solid #8a6a00;
        padding: 6px 16px;
        color: #8aaa60;
        font-size: 11px;
        text-align: center;
    }
</style>

<link href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;600;700&display=swap" rel="stylesheet" />

<div class="jb-wrap">
    <div class="jb-header">
        <div style="color:#8aaa60;font-size:20px;">☰</div>
        <div class="jb-logo">SONHEI COM BICHO</div>
        <div></div>
    </div>

    <div class="jb-body">
        <div class="jb-box">
            <div class="jb-titulo">CADASTRAR JOGADOR</div>
            <form asp-action="Cadastrar" method="post">
                <div class="jb-label">NOME</div>
                <input asp-for="Nome" class="jb-input" placeholder="Digite o nome..." />

                <div class="jb-label">CPF</div>
                <input asp-for="CPF" class="jb-input" placeholder="000.000.000-00" />

                <div class="jb-label">TELEFONE</div>
                <input asp-for="Telefone" class="jb-input" placeholder="(00) 00000-0000" />

                <button type="submit" class="jb-btn">CADASTRAR</button>
            </form>
            <a href="/Jogador/Index" class="jb-voltar">← Voltar para listagem</a>
        </div>
    </div>

    <div class="jb-footer">
        <span>Sonhei Com Bicho — Cadastro de Jogador</span>
    </div>
</div>