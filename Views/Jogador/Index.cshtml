@model List<SonheiComBicho.Models.Jogador>

<h2>Jogadores Cadastrados</h2>

<a href="/Jogador/Cadastrar">+ Novo Jogador</a>

<table class="table">
    <tr>
        <th>Nome</th>
        <th>CPF</th>
        <th>Telefone</th>
        <th>Saldo</th>
        <th>Ações</th>
    </tr>
    @foreach (var j in Model)
    {
        <tr>
            <td><a href="/Aposta/Apostar?jogadorId=@j.Id">@j.Nome</a></td>
            <td>@j.CPF</td>
            <td>@j.Telefone</td>
            <td>R$ @j.Saldo.ToString("F2")</td>
            <td>
                <a href="/Jogador/Depositar?id=@j.Id">Depositar</a> |
                <a href="/Aposta/Historico?jogadorId=@j.Id">Histórico</a>
            </td>
        </tr>
    }
</table>